# Copy to .env and edit.
# For LOCAL use, the defaults are fine — auth is off.

YTD_AUTH_ENABLED=false
YTD_USER=admin
# Generate with:  docker run --rm ytd:local python -c "from app.auth import hash_password; print(hash_password('your-password'))"
YTD_PASS_HASH=

# Override the published image tag when pulling on a server.
# YTD_IMAGE=ghcr.io/your-user/ytd:latest

# Host port to expose locally (server mode uses nginx on :80 instead).
YTD_PORT=8000
